       IDENTIFICATION DIVISION.
       PROGRAM-ID. CUST001.
       ENVIRONMENT DIVISION.
       INPUT-OUTPUT SECTION.
       FILE-CONTROL.
           SELECT CUSTOMER-IN ASSIGN TO CUSTIN.
           SELECT CUSTOMER-OUT ASSIGN TO CUSTOUT.
       DATA DIVISION.
       FILE SECTION.
       FD  CUSTOMER-IN.
       01  CUSTOMER-IN-REC PIC X(80).
       FD  CUSTOMER-OUT.
       01  CUSTOMER-OUT-REC PIC X(80).
       WORKING-STORAGE SECTION.
       COPY CUSTREC.
       PROCEDURE DIVISION.
       MAIN-PARA.
           OPEN INPUT CUSTOMER-IN OUTPUT CUSTOMER-OUT.
           READ CUSTOMER-IN.
           CALL 'CUSTVAL'.
           EXEC SQL
              SELECT CUSTOMER_NAME
                INTO :CUST-NAME
                FROM CUSTOMER_MASTER
               WHERE CUSTOMER_ID = :CUST-ID
           END-EXEC.
           IF CUST-STATUS = 'A'
              WRITE CUSTOMER-OUT-REC
           END-IF.
           GOBACK.
