{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Read(./**)",
      "Bash(git status)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(python -m unittest discover -s tests*)",
      "Bash(python -m compileall src tests)",
      "Bash(python -m mip_intel.cli:*)",
      "Bash(py -m unittest discover -s tests*)",
      "Bash(py -m mip_intel.cli:*)",
      "Bash(npm install)",
      "Bash(npm run build)",
      "Bash(npm run dev:*)",
      "Bash(scan_codebase.bat:*)",
      "Bash(start_ui.bat:*)",
      "Bash(stop_ui.bat:*)",
      "Bash(check_ui.bat:*)"
    ]
  }
}
